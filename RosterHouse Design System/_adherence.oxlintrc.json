{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/containers/**",
              "components/feedback/**",
              "components/forms/**",
              "components/scheduling/**",
              "ui_kits/employee-mobile/**",
              "ui_kits/manager-web/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Figtree))/i]",
        "message": "Font not provided by the design system. Available: Figtree."
      },
      {
        "selector": "JSXOpeningElement[name.name='AvatarStatus'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|status|size|key|ref|className|style|children)$/]",
        "message": "<AvatarStatus> doesn't accept that prop. Declared props: name, status, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='AvatarStatus'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:available|unavailable|pending|off)$/]",
        "message": "<AvatarStatus> status must be one of 'available' | 'unavailable' | 'pending' | 'off'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:success|warning|danger|info|neutral)$/]",
        "message": "<Badge> tone must be one of 'success' | 'warning' | 'danger' | 'info' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|icon|fullWidth|children|onClick|type|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, icon, fullWidth, children, onClick, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|accent|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'accent' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit)$/]",
        "message": "<Button> type must be one of 'button' | 'submit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|padding|hoverable|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, padding, hoverable, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|onChange|disabled|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, checked, onChange, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConflictChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<ConflictChip> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|children|footer|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, onClose, title, children, footer."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|placeholder|value|onChange|type|error|disabled|icon|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, placeholder, value, onChange, type, error, disabled, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='ShiftBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|time|employeeName|status|compact|conflictReason|onClick|key|ref|className|style|children)$/]",
        "message": "<ShiftBlock> doesn't accept that prop. Declared props: role, time, employeeName, status, compact, conflictReason, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='ShiftBlock'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:confirmed|open|conflict|draft)$/]",
        "message": "<ShiftBlock> status must be one of 'confirmed' | 'open' | 'conflict' | 'draft'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|onChange|disabled|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: label, checked, onChange, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|onRemove|color|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, onRemove, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:neutral|brand|accent)$/]",
        "message": "<Tag> color must be one of 'neutral' | 'brand' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|description|onClose|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: tone, title, description, onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:success|warning|danger|info)$/]",
        "message": "<Toast> tone must be one of 'success' | 'warning' | 'danger' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|side|key|ref|className|style|children)$/]",
        "message": "<Tooltip> doesn't accept that prop. Declared props: label, children, side."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute[name.name='side'] > Literal[value!=/^(?:top|bottom)$/]",
        "message": "<Tooltip> side must be one of 'top' | 'bottom'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WeekGridCell'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|empty|hasConflict|onClick|key|ref|className|style|children)$/]",
        "message": "<WeekGridCell> doesn't accept that prop. Declared props: children, empty, hasConflict, onClick."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
