# Local dev: matches docker-compose.yml (docker compose up -d)
# On Railway: reference the Postgres service, e.g. ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://rosterhouse:rosterhouse@localhost:5432/rosterhouse"

# Auth.js session signing secret — generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"

# Public origin used in SMS deep links and password reset links/emails
APP_URL="http://localhost:3000"

# Twilio SMS delivery — leave unset to log SMS to the console instead
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Web push (VAPID) — generate a pair with: npx web-push generate-vapid-keys
# Leave unset to log pushes to the console instead. The public key is
# NEXT_PUBLIC_ because the browser needs it to subscribe.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# Transactional email via Resend (password reset links) — leave unset to log
# emails to the console instead
RESEND_API_KEY=""
EMAIL_FROM="RosterHouse <noreply@example.com>"
